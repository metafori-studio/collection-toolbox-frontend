{
  "name": "@metafori/collection-toolbox-frontend",
  "version": "1.0.0",
  "author": "Metafori",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "check": "npm run lint && npm run type-check && npm run test:unit",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,vue}": [
      "oxlint --fix",
      "eslint --fix --cache"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5"
  }
}
